{
  "id": "arcade-mcp",
  "name": "Arcade MCP Gateway",
  "description": "Connect to one or more MCP gateways with header-based auth. Each gateway exposes its own curated set of tools — the gateway governs access, not the client.",
  "version": "2026.2.11",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean",
        "description": "Enable the plugin",
        "default": true
      },
      "gateways": {
        "type": "object",
        "description": "Named MCP gateway connections. Each key is a gateway name used as the tool prefix.",
        "additionalProperties": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable this gateway",
              "default": true
            },
            "url": {
              "type": "string",
              "description": "MCP gateway endpoint URL (required)"
            },
            "headers": {
              "type": "object",
              "description": "HTTP headers sent with every MCP request (e.g. Authorization, Arcade-User-ID)",
              "additionalProperties": { "type": "string" }
            },
            "toolPrefix": {
              "type": "string",
              "description": "Override the tool name prefix (defaults to the gateway key)"
            }
          },
          "required": ["url", "headers"]
        }
      },
      "requestTimeoutMs": {
        "type": "number",
        "description": "Timeout for MCP requests (ms)",
        "default": 30000
      }
    },
    "required": ["gateways"]
  },
  "uiHints": {
    "enabled": {
      "label": "Enable Plugin"
    },
    "gateways": {
      "label": "MCP Gateways",
      "description": "Configure one or more MCP gateway connections"
    },
    "requestTimeoutMs": {
      "label": "Request Timeout (ms)",
      "advanced": true
    }
  }
}
